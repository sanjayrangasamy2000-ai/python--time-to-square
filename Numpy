# TODO 6.4 : Identify and count outliers in salary using IQR method
​
Q1 = df['salary'].quantile(0.25)
Q3 = df['salary'].quantile(0.75)
IQR = Q3 - Q1
upper_bound = Q3 + 1.5 * IQR
lower_bound = Q1 - 1.5 * IQR
​
outliers = df[(df['salary'] < lower_bound) | (df['salary'] > upper_bound)]
print(f"Number of Salary Outliers: {outliers.shape[0]}")
Number of Salary Outliers: 31
# TODO 6.5: Cap salary outliers at the upper bound
​
df['salary'] = np.where(df['salary'] > upper_bound, upper_bound, df['salary'])
